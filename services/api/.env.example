# AWS Region
AWS_DEFAULT_REGION=us-west-2

# DynamoDB table name for print jobs
DYNAMODB_TABLE=campus-print-jobs

# S3 bucket for document storage
S3_BUCKET=campus-print-docs

# SQS queue URLs as JSON map: {"printer-1": "https://sqs...", "printer-2": "https://sqs..."}
SQS_QUEUE_URLS={}

# Maximum upload file size in bytes (default: 50 MB)
MAX_UPLOAD_BYTES=52428800
